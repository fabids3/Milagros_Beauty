# ============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO — Milagro's Beauty
# ----------------------------------------------------------------------------
# Cómo usar:
#   1) Copia este archivo y renómbralo a ".env"  (sin la extensión .example)
#   2) Ajusta los valores a tu entorno local (XAMPP)
#   3) NUNCA subas el archivo .env real al repositorio (está en .gitignore)
#
# Este archivo SÍ se sube al repositorio porque sirve de plantilla pública.
# ============================================================================

# --- Entorno de ejecución --------------------------------------------------
# Valores válidos: development | production | testing
FLASK_ENV=development
FLASK_DEBUG=1

# --- Clave secreta para firmar las cookies de sesión -----------------------
# Genera una nueva con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_aleatoria_de_64_caracteres

# --- Conexión a MySQL (XAMPP / phpMyAdmin) ---------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
